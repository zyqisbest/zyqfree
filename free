-- SHARED UTILITIES --

local function loadRemoteScript(url)
    local success, result = pcall(function()
        local source = game:HttpGet(url)
        if not source or source == "" then
            warn("[zyqfree] Empty response from: " .. url)
            return
        end
        local fn, compileErr = loadstring(source)
        if not fn then
            warn("[zyqfree] Failed to compile script from: " .. url .. " | " .. tostring(compileErr))
            return
        end
        fn()
    end)
    if not success then
        warn("[zyqfree] Error loading script from: " .. url .. " | " .. tostring(result))
    end
end

local function createScriptButton(section, name, description, url)
    section:NewButton(name, description, function()
        loadRemoteScript(url)
    end)
end

local function getHumanoid()
    local character = game.Players.LocalPlayer and game.Players.LocalPlayer.Character
    if not character then
        warn("[zyqfree] Character not loaded yet")
        return nil
    end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        warn("[zyqfree] Humanoid not found on character")
        return nil
    end
    return humanoid
end

