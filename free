-- Helper: safely load and execute a remote script, warning on failure
local function safeLoadUrl(url)
    local success, result = pcall(function()
        local source = game:HttpGet(url)
        if not source or source == "" then
            warn("[zyqfree] Empty response from: " .. url)
            return
        end
        local fn, compileErr = loadstring(source)
        if not fn then
            warn("[zyqfree] Failed to compile script from: " .. url .. " | " .. tostring(compileErr))
            return
        end
        fn()
    end)
    if not success then
        warn("[zyqfree] Error loading script from: " .. url .. " | " .. tostring(result))
    end
end

