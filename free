-- Allowed remote script domains (whitelist)
local ALLOWED_DOMAINS = {
    "raw.githubusercontent.com",
    "cdn.wearedevs.net",
}

local function isDomainAllowed(url)
    for _, domain in ipairs(ALLOWED_DOMAINS) do
        if string.find(url, domain, 1, true) then
            return true
        end
    end
    return false
end

local function safeLoadUrl(url)
    if type(url) ~= "string" or url == "" then
        warn("[SafeLoad] Invalid URL")
        return nil
    end

    if not string.match(url, "^https://") then
        warn("[SafeLoad] Blocked non-HTTPS URL: " .. url)
        return nil
    end

    if not isDomainAllowed(url) then
        warn("[SafeLoad] Blocked untrusted domain: " .. url)
        return nil
    end

    local ok, source = pcall(function()
        return game:HttpGet(url)
    end)

    if not ok or type(source) ~= "string" or source == "" then
        warn("[SafeLoad] Failed to fetch: " .. url)
        return nil
    end

    local fn, compileErr = loadstring(source)
    if not fn then
        warn("[SafeLoad] Compile error from " .. url .. ": " .. tostring(compileErr))
        return nil
    end

    local success, result = pcall(fn)
    if not success then
        warn("[SafeLoad] Runtime error from " .. url .. ": " .. tostring(result))
        return nil
    end

    return result
end

